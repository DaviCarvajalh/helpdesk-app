# ── Base de datos ──────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://helpdesk:CAMBIA_ESTA_CONTRASEÑA@localhost:5432/helpdesk"

# ── JWT / Sesión ───────────────────────────────────────────────────────────────
# Genera con: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="GENERA_UN_SECRETO_DE_AL_MENOS_48_CHARS"
JWT_EXPIRES_IN="8h"

# ── Cifrado de credenciales ────────────────────────────────────────────────────
# Debe tener EXACTAMENTE 32 caracteres
# Genera con: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
ENCRYPTION_KEY="GENERA_32_CHARS_EXACTOS_AQUI!!!!"

# ── URL de la aplicación ───────────────────────────────────────────────────────
APP_URL="https://tudominio.com"

# ── Email (Resend) ─────────────────────────────────────────────────────────────
# Obtén tu API key en https://resend.com (plan gratuito: 3000 emails/mes)
# Si no se configura, los emails se ignoran silenciosamente
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxx"
EMAIL_FROM="HelpDesk <helpdesk@tudominio.com>"

# ── Seed inicial (opcional) ───────────────────────────────────────────────────
# Si se definen, el seed usará estos valores para crear el usuario administrador
# Si no se definen, se usa admin@helpdesk.cl / Admin1234! (cambiar inmediatamente)
# ADMIN_EMAIL="admin@tuempresa.com"
# ADMIN_PASSWORD="ContraseñaSegura123!"

# ── LDAP / Active Directory (opcional) ────────────────────────────────────────
# Si no usas AD, deja estas variables vacías o no las incluyas
# La configuración también puede gestionarse desde UI → Configuración → Active Directory
# LDAP_ENABLED=false
# LDAP_URL=ldap://dc.empresa.com:389
# LDAP_DOMAIN=empresa.com
# LDAP_BASE_DN=DC=empresa,DC=com
# LDAP_BIND_DN=CN=svc-helpdesk,OU=Servicios,DC=empresa,DC=com
# LDAP_BIND_PASSWORD=contraseña_cuenta_servicio
# LDAP_GROUP_ADMIN=helpdesk-admin
# LDAP_GROUP_SUPERVISOR=helpdesk-supervisor
# LDAP_GROUP_TECNICO=helpdesk-tecnico
# LDAP_GROUP_AUDITOR=helpdesk-auditor
# LDAP_ROLE_DEFAULT=Usuario Final
